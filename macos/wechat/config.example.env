# Native WeChat reader config. Copy to config.env (gitignored) and source it.

# --- bridge ---
export WECHAT_BRIDGE_TOKEN=""        # openssl rand -hex 16  (Bearer token; parity with WeFlow)

# --- point the harness at our bridge instead of WeFlow (ingest.py reads these) ---
export WEFLOW_BASE="http://127.0.0.1:5031"
export WEFLOW_TOKEN="$WECHAT_BRIDGE_TOKEN"

# --- key acquisition: set EXACTLY ONE (wechat_db.py tries them in this order) ---
# 1) explicit key (skip extraction): 64 hex chars
export WECHAT_DB_KEY=""
# 2) WeFlow's signed helper (Option A bootstrap) — path to the lifted xkey_helper
export WXKEY_HELPER=""
# 3) our own extractor (Option B) — path to the built+signed wxkey
export WXKEY=""

# vision for media post-processing (unchanged from the Windows setup)
export ANTHROPIC_API_KEY=""
